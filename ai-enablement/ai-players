<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AI Landscape Briefing | Major Players & Tier Analysis</title>
<meta name="description" content="A clear breakdown of the major AI players, their positions, and where the next war is being fought.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=IBM+Plex+Mono:wght@400;600&family=Source+Serif+4:ital,wght@0,300;0,400;0,600;1,300;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --ink: #0d0f0e;
  --paper: #f5f2eb;
  --paper-2: #ece8df;
  --paper-3: #e2ddd2;
  --rule: #c8c2b4;
  --rule-lt: #ddd8ce;
  --text: #1a1c1b;
  --text-2: #4a4d4b;
  --text-3: #7a7d7a;
  --accent: #b8340a;
  --accent-2: #1a4d2e;
  --gold: #c49a22;
  --blue-ink: #1a2d4a;
  --mono: 'IBM Plex Mono', monospace;
  --serif: 'Source Serif 4', Georgia, serif;
  --display: 'Playfair Display', Georgia, serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { font-size: 16px; scroll-behavior: smooth; }

body {
  background: var(--paper);
  color: var(--text);
  font-family: var(--serif);
  font-weight: 300;
  line-height: 1.7;
  min-height: 100vh;
}

/* ── MASTHEAD ─────────────────────────────────────── */
.masthead {
  background: var(--ink);
  padding: 0;
  border-bottom: 3px solid var(--accent);
  position: relative;
  overflow: hidden;
}
.masthead::after {
  content: '';
  position: absolute;
  top: 0; right: 0;
  width: 40%;
  height: 100%;
  background: repeating-linear-gradient(
    90deg,
    transparent,
    transparent 2px,
    rgba(255,255,255,0.015) 2px,
    rgba(255,255,255,0.015) 4px
  );
  pointer-events: none;
}
.masthead-inner {
  max-width: 1160px;
  margin: 0 auto;
  padding: 40px 40px 36px;
  position: relative;
  z-index: 1;
}
.masthead-kicker {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.masthead-kicker::before {
  content: '';
  display: inline-block;
  width: 20px;
  height: 1px;
  background: var(--accent);
}
.masthead h1 {
  font-family: var(--display);
  font-size: clamp(2.4rem, 5vw, 4.2rem);
  font-weight: 900;
  color: #f5f2eb;
  line-height: 1.0;
  letter-spacing: -0.02em;
  margin-bottom: 20px;
  max-width: 780px;
}
.masthead h1 em {
  color: var(--accent);
  font-style: italic;
}
.masthead-meta {
  display: flex;
  align-items: center;
  gap: 24px;
  flex-wrap: wrap;
}
.masthead-byline {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: rgba(245,242,235,0.5);
  letter-spacing: 0.06em;
}
.masthead-tag {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 3px 10px;
  border: 1px solid rgba(245,242,235,0.2);
  border-radius: 2px;
  color: rgba(245,242,235,0.5);
}

/* ── LAYOUT ──────────────────────────────────────── */
.page-wrap {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 40px 80px;
}

/* ── SECTION LABELS ──────────────────────────────── */
.section-rule {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 48px 0 28px;
}
.section-rule-label {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-3);
  white-space: nowrap;
}
.section-rule-line {
  flex: 1;
  height: 1px;
  background: var(--rule);
}

/* ── PLAYER GRID ─────────────────────────────────── */
.player-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: var(--rule);
  border: 1px solid var(--rule);
  border-radius: 4px;
  overflow: hidden;
  margin-bottom: 2px;
}
.player-grid.two-col {
  grid-template-columns: repeat(2, 1fr);
}

.player-card {
  background: var(--paper);
  padding: 28px 26px 24px;
  position: relative;
  transition: background 0.18s;
}
.player-card:hover { background: var(--paper-2); }

.player-num {
  font-family: var(--mono);
  font-size: 0.6rem;
  font-weight: 600;
  color: var(--text-3);
  letter-spacing: 0.1em;
  margin-bottom: 10px;
}
.player-name {
  font-family: var(--display);
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--text);
  line-height: 1.15;
  margin-bottom: 4px;
}
.player-model {
  font-family: var(--mono);
  font-size: 0.7rem;
  color: var(--accent-2);
  font-weight: 600;
  letter-spacing: 0.06em;
  margin-bottom: 14px;
}
.player-meta {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-bottom: 16px;
  padding-bottom: 14px;
  border-bottom: 1px solid var(--rule-lt);
}
.player-meta-row {
  display: flex;
  gap: 8px;
  font-size: 0.8rem;
  line-height: 1.4;
}
.player-meta-key {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 600;
  color: var(--text-3);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  min-width: 52px;
  margin-top: 1px;
  flex-shrink: 0;
}
.player-meta-val {
  color: var(--text-2);
  font-size: 0.82rem;
}
.player-notable {
  list-style: none;
  padding: 0;
  margin: 0 0 16px;
  display: flex;
  flex-direction: column;
  gap: 5px;
}
.player-notable li {
  font-size: 0.83rem;
  color: var(--text-2);
  line-height: 1.45;
  padding-left: 14px;
  position: relative;
}
.player-notable li::before {
  content: '\2013';
  position: absolute;
  left: 0;
  color: var(--rule);
}
.player-position {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-family: var(--mono);
  font-size: 0.67rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--accent);
  text-transform: uppercase;
  padding: 5px 10px;
  background: rgba(184,52,10,0.07);
  border: 1px solid rgba(184,52,10,0.18);
  border-radius: 2px;
}
.player-position::before {
  content: '';
  display: inline-block;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
}
.player-position.blue {
  color: var(--blue-ink);
  background: rgba(26,45,74,0.06);
  border-color: rgba(26,45,74,0.18);
}
.player-position.blue::before { background: var(--blue-ink); }
.player-position.gold {
  color: var(--gold);
  background: rgba(196,154,34,0.07);
  border-color: rgba(196,154,34,0.25);
}
.player-position.gold::before { background: var(--gold); }
.player-position.green {
  color: var(--accent-2);
  background: rgba(26,77,46,0.07);
  border-color: rgba(26,77,46,0.2);
}
.player-position.green::before { background: var(--accent-2); }

/* Special card: warning */
.player-card.correction {
  background: #fdf7f0;
  border-left: 3px solid var(--gold);
}
.player-card.correction:hover { background: #faf0e4; }
.correction-label {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.correction-candidates {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin: 12px 0 14px;
}
.correction-candidate {
  font-size: 0.85rem;
  color: var(--text-2);
  padding: 7px 12px;
  background: var(--paper-2);
  border-radius: 3px;
  border-left: 2px solid var(--rule);
}
.correction-candidate strong {
  color: var(--text);
  font-weight: 600;
}

/* ── TIER SECTION ────────────────────────────────── */
.tier-wrap {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
  margin-bottom: 16px;
}
.tier-card {
  padding: 26px 24px;
  border-radius: 3px;
}
.tier-card.t1 {
  background: var(--ink);
  border: 1px solid rgba(245,242,235,0.06);
}
.tier-card.t2 {
  background: var(--paper-2);
  border: 1px solid var(--rule);
}
.tier-card.t3 {
  background: var(--paper-2);
  border: 1px solid var(--rule);
}
.tier-label {
  font-family: var(--mono);
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.tier-card.t1 .tier-label { color: rgba(245,242,235,0.4); }
.tier-card.t2 .tier-label { color: var(--text-3); }
.tier-card.t3 .tier-label { color: var(--text-3); }
.tier-title {
  font-family: var(--display);
  font-size: 1.05rem;
  font-weight: 700;
  margin-bottom: 16px;
}
.tier-card.t1 .tier-title { color: #f5f2eb; }
.tier-card.t2 .tier-title { color: var(--text); }
.tier-card.t3 .tier-title { color: var(--text); }
.tier-names {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.tier-name {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.88rem;
  font-weight: 600;
}
.tier-card.t1 .tier-name { color: #f5f2eb; }
.tier-card.t2 .tier-name { color: var(--text); }
.tier-card.t3 .tier-name { color: var(--text); }
.tier-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}
.t1 .tier-dot { background: var(--accent); }
.t2 .tier-dot { background: var(--gold); }
.t3 .tier-dot { background: var(--rule); }
.tier-sub {
  font-size: 0.75rem;
  font-weight: 400;
  margin-left: 14px;
}
.tier-card.t1 .tier-sub { color: rgba(245,242,235,0.45); }
.tier-card.t2 .tier-sub { color: var(--text-3); }
.tier-card.t3 .tier-sub { color: var(--text-3); }

/* ── NEW LAYER ───────────────────────────────────── */
.new-layer-card {
  background: var(--accent-2);
  padding: 26px 28px;
  border-radius: 3px;
  display: flex;
  align-items: center;
  gap: 32px;
}
.new-layer-label {
  font-family: var(--mono);
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: rgba(245,242,235,0.5);
  margin-bottom: 6px;
}
.new-layer-title {
  font-family: var(--display);
  font-size: 1.05rem;
  font-weight: 700;
  color: #f5f2eb;
  margin-bottom: 4px;
}
.new-layer-note {
  font-size: 0.82rem;
  color: rgba(245,242,235,0.6);
}
.new-layer-badge {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 5px 12px;
  background: rgba(245,242,235,0.12);
  border: 1px solid rgba(245,242,235,0.2);
  border-radius: 2px;
  color: #f5f2eb;
  white-space: nowrap;
}

/* ── THE THREE LAYERS ────────────────────────────── */
.layers-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: var(--rule);
  border: 1px solid var(--rule);
  border-radius: 4px;
  overflow: hidden;
}
.layer-card {
  background: var(--paper);
  padding: 30px 26px;
  position: relative;
}
.layer-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 3px;
}
.layer-card.lc-1::before { background: var(--accent); }
.layer-card.lc-2::before { background: var(--gold); }
.layer-card.lc-3::before { background: var(--accent-2); }
.layer-num {
  font-family: var(--mono);
  font-size: 2rem;
  font-weight: 600;
  color: var(--rule);
  line-height: 1;
  margin-bottom: 12px;
}
.layer-title {
  font-family: var(--display);
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 10px;
  line-height: 1.2;
}
.layer-examples {
  font-family: var(--mono);
  font-size: 0.72rem;
  color: var(--text-3);
  margin-bottom: 14px;
  letter-spacing: 0.03em;
}
.layer-desc {
  font-size: 0.87rem;
  color: var(--text-2);
  line-height: 1.6;
}

/* ── INSIGHT BOX ─────────────────────────────────── */
.insight-box {
  background: var(--ink);
  padding: 44px 48px;
  margin-top: 16px;
  border-radius: 3px;
  position: relative;
  overflow: hidden;
}
.insight-box::before {
  content: '\201C';
  position: absolute;
  top: -20px;
  right: 24px;
  font-family: var(--display);
  font-size: 14rem;
  color: rgba(245,242,235,0.04);
  line-height: 1;
  pointer-events: none;
}
.insight-label {
  font-family: var(--mono);
  font-size: 0.62rem;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.insight-label::before {
  content: '';
  display: inline-block;
  width: 16px;
  height: 1px;
  background: var(--accent);
}
.insight-box h3 {
  font-family: var(--display);
  font-size: clamp(1.4rem, 2.5vw, 2rem);
  font-weight: 700;
  color: #f5f2eb;
  line-height: 1.25;
  margin-bottom: 20px;
  max-width: 760px;
}
.insight-box h3 em {
  color: var(--accent);
  font-style: italic;
}
.insight-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  margin-top: 10px;
}
.insight-point {
  padding-top: 18px;
  border-top: 1px solid rgba(245,242,235,0.1);
}
.insight-point-label {
  font-family: var(--mono);
  font-size: 0.65rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(245,242,235,0.35);
  margin-bottom: 8px;
}
.insight-point p {
  font-size: 0.9rem;
  color: rgba(245,242,235,0.65);
  line-height: 1.65;
}
.insight-point strong {
  color: #f5f2eb;
  font-weight: 600;
}

/* ── FOOTER ──────────────────────────────────────── */
.page-footer {
  border-top: 1px solid var(--rule);
  padding: 24px 0 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 48px;
}
.page-footer-note {
  font-family: var(--mono);
  font-size: 0.65rem;
  color: var(--text-3);
  letter-spacing: 0.06em;
}

/* ── STAGGER ANIMATION ───────────────────────────── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(14px); }
  to   { opacity: 1; transform: translateY(0); }
}
.player-card, .tier-card, .layer-card {
  animation: fadeUp 0.4s ease both;
}
.player-grid .player-card:nth-child(1)  { animation-delay: 0.05s; }
.player-grid .player-card:nth-child(2)  { animation-delay: 0.10s; }
.player-grid .player-card:nth-child(3)  { animation-delay: 0.15s; }
.player-grid .player-card:nth-child(4)  { animation-delay: 0.20s; }
.player-grid .player-card:nth-child(5)  { animation-delay: 0.25s; }
.player-grid .player-card:nth-child(6)  { animation-delay: 0.30s; }
.player-grid .player-card:nth-child(7)  { animation-delay: 0.35s; }
.player-grid .player-card:nth-child(8)  { animation-delay: 0.40s; }
.player-grid .player-card:nth-child(9)  { animation-delay: 0.45s; }

/* ── RESPONSIVE ──────────────────────────────────── */
@media (max-width: 900px) {
  .player-grid, .player-grid.two-col { grid-template-columns: 1fr 1fr; }
  .tier-wrap { grid-template-columns: 1fr; }
  .layers-grid { grid-template-columns: 1fr; }
  .insight-two-col { grid-template-columns: 1fr; gap: 24px; }
  .new-layer-card { flex-direction: column; gap: 16px; align-items: flex-start; }
  .page-wrap { padding: 0 24px 60px; }
  .masthead-inner { padding: 32px 24px 28px; }
}
@media (max-width: 600px) {
  .player-grid, .player-grid.two-col { grid-template-columns: 1fr; }
  .insight-box { padding: 28px 24px; }
}
</style>
</head>
<body>

<!-- ── MASTHEAD ───────────────────────────────────────────── -->
<div class="masthead">
  <div class="masthead-inner">
    <div class="masthead-kicker">Intelligence Briefing</div>
    <h1>Major AI Players:<br><em>A Clear Breakdown</em></h1>
    <div class="masthead-meta">
      <span class="masthead-byline">Human Layer Systems &nbsp;&middot;&nbsp; AI Strategy &amp; Enablement</span>
      <span class="masthead-tag">Reference Document</span>
      <span class="masthead-tag">Updated 2025</span>
    </div>
  </div>
</div>

<!-- ── MAIN CONTENT ───────────────────────────────────────── -->
<div class="page-wrap">

  <!-- Players grid -->
  <div class="section-rule">
    <span class="section-rule-label">The players</span>
    <div class="section-rule-line"></div>
    <span class="section-rule-label">10 entries</span>
  </div>

  <div class="player-grid">

    <!-- 01 OpenAI -->
    <div class="player-card">
      <div class="player-num">01 &mdash; Frontier</div>
      <div class="player-name">OpenAI</div>
      <div class="player-model">GPT &nbsp;/&nbsp; ChatGPT</div>
      <div class="player-meta">
        <div class="player-meta-row">
          <span class="player-meta-key">Founded</span>
          <span class="player-meta-val">2015 &mdash; GPT models began ~2018</span>
        </div>
        <div class="player-meta-row">
          <span class="player-meta-key">Backed by</span>
          <span class="player-meta-val">OpenAI + deep Microsoft partnership</span>
        </div>
      </div>
      <ul class="player-notable">
        <li>Creator of ChatGPT</li>
        <li>Pioneer of the modern generative AI boom</li>
        <li>Strong in reasoning, coding, multimodal systems</li>
      </ul>
      <span class="player-position">Center of gravity in enterprise AI</span>
    </div>

    <!-- 02 Anthropic -->
    <div class="player-card">
      <div class="player-num">02 &mdash; Frontier</div>
      <div class="player-name">Anthropic</div>
      <div class="player-model">Claude</div>
      <div class="player-meta">
        <div class="player-meta-row">
          <span class="player-meta-key">Founded</span>
          <span class="player-meta-val">2021</span>
        </div>
        <div class="player-meta-row">
          <span class="player-meta-key">Backed by</span>
          <span class="player-meta-val">Anthropic &mdash; major Amazon &amp; Google investment</span>
        </div>
      </div>
      <ul class="player-notable">
        <li>Heavy focus on AI safety and alignment</li>
        <li>Strong long-context and reasoning performance</li>
        <li>Main rival to OpenAI in quality and safety</li>
      </ul>
      <span class="player-position">Main rival to OpenAI in quality + safety</span>
    </div>

    <!-- 03 Google -->
    <div class="player-card">
      <div class="player-num">03 &mdash; Frontier</div>
      <div class="player-name">Google</div>
      <div class="player-model">Gemini</div>
      <div class="player-meta">
        <div class="player-meta-row">
          <span class="player-meta-key">Founded</span>
          <span class="player-meta-val">AI since 2010s &mdash; Gemini launched 2023</span>
        </div>
        <div class="player-meta-row">
          <span class="player-meta-key">Owned by</span>
          <span class="player-meta-val">Alphabet</span>
        </div>
      </div>
      <ul class="player-notable">
        <li>Invented the transformer architecture (all modern AI builds on this)</li>
        <li>Multimodal models: text, image, video</li>
        <li>Deep integration into Search, Android, and Workspace</li>
      </ul>
      <span class="player-position blue">Most vertically integrated AI ecosystem</span>
    </div>

    <!-- 04 xAI -->
    <div class="player-card">
      <div class="player-num">04 &mdash; Ecosystem</div>
      <div class="player-name">xAI</div>
      <div class="player-model">Grok</div>
      <div class="player-meta">
        <div class="player-meta-row">
          <span class="player-meta-key">Founded</span>
          <span class="player-meta-val">2023</span>
        </div>
